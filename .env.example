# Last.fm API Configuration - Backend (server)
# Get your API key from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# Frontend (if needed for direct calls)
VITE_LASTFM_API_KEY=your_lastfm_api_key_here

# OpenStreetMap is free and requires no API key

# Server Configuration
PORT=3001
